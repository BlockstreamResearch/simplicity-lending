  "query": "\n        SELECT DISTINCT ON (participant_type)\n            offer_id,\n            participant_type AS \"participant_type: ParticipantType\",\n            script_pubkey,\n            txid,\n            vout,\n            created_at_height,\n            spent_txid,\n            spent_at_height\n        FROM offer_participants\n        WHERE offer_id = $1\n        ORDER BY participant_type, created_at_height DESC\n        ",
