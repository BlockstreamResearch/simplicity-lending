FROM node:22-bookworm AS builder

WORKDIR /app/web
RUN corepack enable && \
    corepack prepare pnpm@10.33.0 --activate

COPY web/package.json web/pnpm-lock.yaml ./

RUN pnpm install --frozen-lockfile

COPY web ./
COPY crates/contracts/simf /app/crates/contracts/simf

ARG VITE_API_URL
ARG VITE_ESPLORA_BASE_URL
ARG VITE_NETWORK
ARG VITE_WATERFALLS_URL
ARG VITE_WATERFALLS_RECIPIENT=age1xxzrgrfjm3yrwh3u6a7exgrldked0pdauvr3mx870wl6xzrwm5ps8s2h0p
ARG VITE_DEBUG_MNEMONIC
ENV VITE_API_URL=$VITE_API_URL
ENV VITE_ESPLORA_BASE_URL=$VITE_ESPLORA_BASE_URL
ENV VITE_NETWORK=$VITE_NETWORK
ENV VITE_WATERFALLS_URL=$VITE_WATERFALLS_URL
ENV VITE_WATERFALLS_RECIPIENT=$VITE_WATERFALLS_RECIPIENT
ENV VITE_DEBUG_MNEMONIC=$VITE_DEBUG_MNEMONIC

RUN pnpm build

FROM nginx:1.27-alpine

RUN apk add --no-cache gettext

COPY --from=builder /app/web/dist /usr/share/nginx/html
COPY deployment/configs /deployment/configs
COPY deployment/scripts/render-web-config.sh /deployment/render-web-config.sh

ENTRYPOINT ["/deployment/render-web-config.sh"]
CMD ["nginx", "-g", "daemon off;"]
